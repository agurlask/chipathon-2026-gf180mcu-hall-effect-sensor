* noconn #net19
* noconn #net20
I0 vdd ibias_main_ota_pres 100n
I1 vdd ibias_main_ota 10u
I2 vdd ibias_rrl_pres 100n
I3 ibias_rrl_gm4 vss 10u
I4 ibias_rrl_gm3 vss 10u
V7 vcm vss {vcm}
E1 vin_p vcm vin vss 0.5
E2 vin_n vcm vin vss -0.5
V5 vdd vss 3.3
V6 vss 0 0
V1 vin vss SIN(0 {vd} 10e3)
V2 phi1 vss PULSE(3.3 0 0 500p 500p {tper/2+tdead+500p} {tper})
V8 phi2 vss PULSE(3.3 0 {tper/2} 500p 500p {tper/2+tdead+500p} {tper})
